{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc", "react", "import", "promise"],
  "jsPlugins": ["oxlint-tailwindcss"],
  "categories": {
    "correctness": "error",
    "suspicious": "error"
  },
  "settings": {
    "next": {
      "rootDir": "apps/web/"
    },
    "tailwindcss": {
      "entryPoint": "packages/ui/src/styles/globals.css"
    }
  },
  "options": {
    "typeAware": true,
    "reportUnusedDisableDirectives": "error"
  },
  "rules": {
    "react/react-in-jsx-scope": "off",
    "typescript/no-floating-promises": "off",
    // TODO: Fix below all rules later
    "typescript/no-unsafe-type-assertion": "off",
    "import/no-unassigned-import": [
      "error",
      {
        "allow": [
          "**/*.css",
          "server-only",
          "**/*.d.ts",
          "@total-typescript/ts-reset/**"
        ]
      }
    ],
    "promise/always-return": ["error", { "ignoreLastCallback": true }],
    "no-underscore-dangle": ["error", { "allow": ["_default"] }]
  },
  "overrides": [
    {
      "files": ["apps/web/**/*.{ts,tsx}"],
      "plugins": ["nextjs"]
    },
    {
      "files": [
        "apps/extension/**/*.{ts,tsx}",
        "apps/web/**/*.{ts,tsx}",
        "packages/shared/**/*.{ts,tsx}"
      ],
      "rules": { "react/react-compiler": "error" }
    },
    {
      "files": ["apps/*/tests/**/*.ts"],
      "rules": { "no-empty-pattern": "off" }
    }
  ],
  "ignorePatterns": [
    "apps/web/next-env.d.ts",
    "apps/extension/.output/**",
    "apps/extension/.wxt/**",
    "packages/ui/**"
  ]
}
